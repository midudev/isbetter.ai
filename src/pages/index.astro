---
import Layout from "../layouts/Layout.astro";
import ArenaFooter from "../components/ArenaFooter.astro";
import ArenaHeader from "../components/ArenaHeader.astro";
import ViewToolbar from "../components/ViewToolbar.astro";
import { PROVIDER_LIST } from "../scripts/providers/registry";

const PROMPT_EXAMPLES = [
	{
		label: "Pricing page",
		prompt: "Build a responsive SaaS pricing page with three tiers, a monthly/yearly billing toggle, a feature comparison, and a clear highlighted plan.",
	},
	{
		label: "Analytics dashboard",
		prompt: "Build a polished analytics dashboard with KPI cards, an interactive revenue chart, a recent activity feed, and a responsive sidebar.",
	},
	{
		label: "Kanban board",
		prompt: "Build an interactive Kanban board with draggable task cards, three workflow columns, priority labels, and a form to add new tasks.",
	},
	{
		label: "Music player",
		prompt: "Build a modern music player with album artwork, playback controls, a seek bar, volume control, and an interactive track queue.",
	},
];
---

<Layout>
	<div class="app-shell flex flex-col">
		<ArenaHeader />

		<main class="flex-1 pb-8">
			<section class="arena-intro pb-6 pt-8 lg:pb-7 lg:pt-10">
				<h1 class="max-w-3xl text-balance text-[clamp(2rem,4.5vw,3.75rem)] font-semibold leading-[1.02] tracking-[-0.05em] text-[var(--color-ink)]">
					Compare AI models. Side by side.
				</h1>
				<p class="mt-3 max-w-2xl text-[13px] leading-6 text-[var(--color-ink-dim)] sm:text-[14px]">
					Give every model the same prompt and compare the answer, code, preview, speed, and cost.
				</p>
			</section>

			<section class="battle-composer panel-premium overflow-visible" aria-labelledby="battle-builder-title">
				<h2 id="battle-builder-title" class="sr-only">Configure a new battle</h2>

				<div class="grid lg:grid-cols-[minmax(18rem,0.82fr)_minmax(0,1.45fr)]">
					<div class="min-w-0 border-b border-[var(--color-line)] p-4 sm:p-5 lg:border-b-0 lg:border-r">
						<div class="flex items-center justify-between gap-3">
							<p class="composer-label">
								<span class="composer-step">01</span>
								Models
							</p>
							<span class="inline-flex items-baseline gap-1.5 whitespace-nowrap text-[11px] text-[var(--color-ink-faint)]">
								<span class="font-semibold tabular-nums text-[var(--color-ink)]"><span id="model-count" aria-live="polite">0</span>/6</span>
								<span>selected</span>
							</span>
						</div>
						<p class="mt-2 text-[12px] leading-relaxed text-[var(--color-ink-faint)]">
							Choose at least two models.
						</p>

						<div class="mt-4 flex min-h-11 flex-wrap items-center gap-2" id="models-chips">
							<div class="relative" id="add-model-wrap">
								<button
									id="add-model-btn"
									aria-expanded="false"
									aria-controls="model-dropdown"
									class="control-surface flex min-h-10 items-center gap-2 border-dashed px-3 text-[12px] hover:!border-[var(--color-accent)]"
									title="add model · shortcut: M"
								>
									<svg class="size-4"><use href="#i-plus"></use></svg>
									<span>Add model</span>
									<kbd class="key-hint">M</kbd>
								</button>

								<div
									id="model-dropdown"
									class="absolute left-0 top-full z-30 mt-2 hidden w-[min(92vw,440px)] overflow-hidden rounded-xl border border-[var(--color-line-hi)] bg-[var(--color-panel)] shadow-2xl"
								>
									<div class="no-scrollbar flex gap-1 overflow-x-auto border-b border-[var(--color-line)] p-1.5" role="tablist" aria-label="Model provider">
									<button type="button" role="tab" aria-selected="true" data-provtab="all" class="flex shrink-0 items-center justify-center gap-1.5 rounded-md px-2.5 py-1.5 text-[11px] transition-colors">
										<svg class="size-4"><use href="#i-world"></use></svg>
										All
									</button>
									{PROVIDER_LIST.map((provider) => (
										<button type="button" role="tab" aria-selected="false" data-provtab={provider.id} class="flex shrink-0 items-center justify-center gap-1.5 rounded-md px-2.5 py-1.5 text-[11px] transition-colors">
											<img
												src={provider.logo}
												alt=""
												class:list={["size-4 object-contain", { "brightness-0 invert": provider.logoMonochrome }]}
											/>
											{provider.short}
											<span data-provider-ready={provider.id} class="hidden size-1 rounded-full bg-emerald-400" title="configured"></span>
										</button>
									))}
									</div>
									<div class="flex items-center gap-2 border-b border-[var(--color-line)] px-3 py-2.5">
										<svg class="size-4 text-[var(--color-ink-faint)]"><use href="#i-search"></use></svg>
										<input
											id="model-search"
											type="text"
											placeholder="Search available models…"
											autocomplete="off"
											spellcheck="false"
											class="w-full bg-transparent text-[12px] text-[var(--color-ink)] outline-none placeholder:text-[var(--color-ink-faint)]"
										/>
									</div>
									<ul id="model-list" role="listbox" class="no-scrollbar max-h-[320px] overflow-y-auto py-1 text-[12px]">
										<li class="px-3 py-6 text-center text-[var(--color-ink-faint)]">loading models…</li>
									</ul>
								</div>
							</div>
					</div>
						<div class="mt-5 border-t border-[var(--color-line)] pt-3">
							<button
								id="sys-toggle"
								class="flex w-full items-center gap-2 py-2 text-left text-[12px] text-[var(--color-ink-dim)] transition-colors hover:text-[var(--color-ink)]"
								title="system prompt · shortcut: S"
								aria-expanded="false"
								aria-controls="sys-panel"
							>
								<svg id="sys-chevron" class="size-4 transition-transform"><use href="#i-chevron"></use></svg>
								<span>Advanced instructions</span>
								<kbd class="key-hint ml-auto">S</kbd>
							</button>
							<div id="sys-panel" class="hidden pt-2">
								<textarea
									id="system-prompt"
									rows="7"
									spellcheck="false"
									aria-label="System prompt"
									class="control-surface no-scrollbar w-full resize-y p-3.5 font-mono text-[11px] leading-relaxed outline-none focus:border-[var(--color-accent)]/50"
								></textarea>
								<div class="mt-2 flex justify-end">
									<button id="sys-reset" class="flex items-center gap-1.5 text-[11px] text-[var(--color-ink-faint)] transition-colors hover:text-[var(--color-ink)]">
										<svg class="size-3.5"><use href="#i-refresh"></use></svg>
										<span>Reset to default</span>
									</button>
								</div>
							</div>
						</div>
					</div>

					<div class="min-w-0 p-4 sm:p-5">
						<div class="flex items-center justify-between gap-3">
							<label class="composer-label" for="prompt">
								<span class="composer-step">02</span>
								Prompt
							</label>
						</div>
						<div id="prompt-shell" class="prompt-shell relative mt-3">
							<textarea
								id="prompt"
								rows="5"
								placeholder="What should every model build?"
								spellcheck="false"
								aria-describedby="prompt-error"
								class="no-scrollbar block w-full resize-y bg-transparent px-4 pb-2 pt-4 text-[14px] leading-relaxed text-[var(--color-ink)] outline-none placeholder:text-[var(--color-ink-faint)] sm:text-[15px]"
							></textarea>
							<div
								id="prompt-examples"
								class="no-scrollbar absolute inset-x-0 bottom-0 flex translate-y-0 items-center gap-1 overflow-x-auto bg-gradient-to-t from-[var(--color-surface)] via-[var(--color-surface)]/95 to-transparent px-3 pb-2 pt-5 opacity-100 transition-[opacity,transform] duration-200 ease-out"
								aria-label="Example prompts"
								aria-hidden="false"
							>
								<span class="shrink-0 px-1 font-pixel text-[9px] uppercase tracking-[0.14em] text-[var(--color-ink-faint)]">Try</span>
								{PROMPT_EXAMPLES.map((example) => (
									<button
										type="button"
										data-prompt-example={example.prompt}
										aria-controls="prompt"
										class="shrink-0 rounded-md px-2.5 py-1.5 text-[11px] text-[var(--color-ink-dim)] transition-colors hover:bg-[var(--color-panel-hi)] hover:text-[var(--color-ink)]"
									>
										{example.label}
									</button>
								))}
							</div>
						</div>
						<div class="mt-3 flex flex-col gap-3 sm:flex-row sm:items-center sm:justify-between">
							<p id="prompt-error" class="hidden text-[11px] text-red-400" role="alert">Write a prompt before starting the battle.</p>
							<div class="flex w-full flex-wrap items-center gap-2 sm:ml-auto sm:w-auto sm:flex-nowrap">
								<button
									id="blind-mode-btn"
									type="button"
									class="control-surface flex min-h-11 flex-1 items-center justify-center gap-2 px-3 text-[11px] sm:flex-none"
									data-tip="Hide model names until you reveal them. Cards are shuffled so you judge quality without knowing who wrote what. Shortcut: B"
									aria-pressed="false"
								>
									<svg class="size-4"><use id="blind-mode-icon" href="#i-eye"></use></svg>
									<span>Blind comparison</span>
									<kbd class="key-hint">B</kbd>
									<span id="blind-mode-check" class="grid size-4 place-items-center rounded border border-[var(--color-line-hi)] text-transparent" aria-hidden="true">
										<svg class="size-3"><use href="#i-check"></use></svg>
									</span>
								</button>
								<button
									id="share-public-btn"
									type="button"
									class="control-surface flex min-h-11 flex-1 items-center justify-center gap-2 px-3 text-[11px] sm:flex-none"
									data-tip="When enabled, successful results are published after the battle and you get a unique shareable URL. Only the prompt and model outputs are uploaded — never API keys or personal data. Fully anonymous."
									aria-pressed="false"
								>
									<svg class="size-4"><use id="share-public-icon" href="#i-world"></use></svg>
									<span>Share public</span>
									<span id="share-public-check" class="grid size-4 place-items-center rounded border border-[var(--color-line-hi)] text-transparent" aria-hidden="true">
										<svg class="size-3"><use href="#i-check"></use></svg>
									</span>
								</button>
								<button
									id="run-btn"
									class="action-primary group flex min-h-11 flex-1 shrink-0 items-center justify-center gap-2 px-5 text-[13px] font-semibold sm:w-auto sm:flex-none"
								>
									<svg id="run-icon" class="size-4"><use href="#i-play"></use></svg>
									<span id="run-label">Run battle</span>
									<kbd id="run-shortcut" class="key-hint key-hint-inverse">⌘↵</kbd>
								</button>
							</div>
						</div>
					</div>
				</div>
			</section>

			<section class="results-stage pt-7 sm:pt-9" aria-labelledby="results-title">
				<header class="flex min-h-11 flex-wrap items-center justify-between gap-3">
					<h2 id="results-title" class="font-pixel text-[14px] tracking-[0.04em] text-[var(--color-ink)]">Results</h2>
					<div id="results-toolbar-wrap" class="hidden">
						<ViewToolbar />
					</div>
				</header>

				<section id="results" role="tabpanel" aria-label="Model results" class="grid flex-1 content-start gap-4 py-4 sm:py-5 grid-cols-[repeat(auto-fill,minmax(min(22rem,100%),1fr))]">
					<div id="empty-state" class="col-span-full flex items-center gap-3 rounded-xl border border-dashed border-[var(--color-line)] px-4 py-5 text-[12px] text-[var(--color-ink-faint)]">
						<svg class="size-4 shrink-0"><use href="#i-vs"></use></svg>
						<p>Run a battle to compare every model here.</p>
						</div>
				</section>
			</section>

		<section id="battle-summary" class="mb-6 hidden overflow-hidden">
			<header class="flex flex-wrap items-center gap-3 border-b border-[var(--color-line)] px-4 py-3.5 sm:px-5">
				<svg class="size-4 text-[var(--color-accent)]"><use href="#i-trophy"></use></svg>
				<div>
					<h2 class="font-pixel text-[11px] uppercase tracking-[0.14em] text-[var(--color-ink)]">Battle analysis</h2>
					<p class="mt-0.5 text-[10px] text-[var(--color-ink-faint)]">Performance and cost, normalized side by side</p>
				</div>
			</header>
			<div class="grid border-b border-[var(--color-line)] lg:grid-cols-[minmax(0,2fr)_minmax(16rem,1fr)]">
				<div id="battle-timeline" class="min-w-0 border-b border-[var(--color-line)] lg:border-b-0 lg:border-r"></div>
				<aside id="battle-insights"></aside>
			</div>
			<div class="scroll-affordance"><div id="battle-summary-list" class="overflow-x-auto"></div></div>
		</section>
		<section id="share-panel" class="mb-6 hidden py-4" aria-labelledby="share-title">
			<div class="flex flex-col gap-4 sm:flex-row sm:items-center sm:justify-between">
				<div class="flex max-w-3xl items-start gap-3">
					<span class="grid size-9 shrink-0 place-items-center rounded-lg bg-[var(--color-accent)]/10 text-[var(--color-accent)]">
						<svg class="size-4"><use href="#i-world"></use></svg>
					</span>
					<div>
						<h2 id="share-title" class="text-[13px] text-[var(--color-ink)]">Share these results?</h2>
						<p class="mt-1 text-[11px] leading-relaxed text-[var(--color-ink-faint)]">
							Optional and fully anonymous. Only the prompt and successful model results are uploaded —
							never your API keys, system prompt, or any personal information. Publishing creates a unique URL you can copy and share.
						</p>
						<p id="share-status" class="mt-2 hidden text-[11px]" role="status" aria-live="polite"></p>
						<div id="share-url-row" class="mt-3 hidden flex-wrap items-center gap-2">
							<input
								id="share-url"
								type="text"
								readonly
								class="min-w-0 flex-1 rounded-lg border border-[var(--color-line-hi)] bg-[var(--color-panel)] px-3 py-2 font-mono text-[11px] text-[var(--color-ink)] outline-none focus:border-[var(--color-accent)]"
								aria-label="Public battle URL"
							/>
						</div>
					</div>
				</div>
				<button
					id="share-battle-btn"
					type="button"
					class="flex shrink-0 items-center justify-center gap-2 rounded-lg bg-[var(--color-accent)] px-4 py-2.5 text-[12px] font-medium text-black transition-opacity hover:opacity-90 disabled:cursor-wait disabled:opacity-50"
				>
					<svg class="size-4"><use href="#i-world"></use></svg>
					<span>Publish &amp; get link</span>
				</button>
			</div>
		</section>
		</main>

		<ArenaFooter />
	</div>

	<!-- ============================== API KEY MODAL ============================== -->
	<div id="key-modal" class="fixed inset-0 z-50 hidden" role="dialog" aria-modal="true" aria-labelledby="key-modal-title">
		<div id="key-backdrop" class="absolute inset-0 bg-black/80 backdrop-blur-md"></div>
		<div class="panel-premium absolute left-1/2 top-1/2 w-[min(92vw,480px)] -translate-x-1/2 -translate-y-1/2 p-5 shadow-2xl sm:p-6">
			<div class="flex items-center gap-2.5">
				<span class="grid size-10 place-items-center rounded-xl bg-[var(--color-accent)]/10 text-[var(--color-accent)]">
					<svg class="size-5"><use href="#i-key"></use></svg>
				</span>
				<div>
					<h2 id="key-modal-title" class="text-[14px] font-medium text-[var(--color-ink)]">Connect providers</h2>
					<p class="mt-0.5 text-[11px] text-[var(--color-ink-faint)]">Keys stay in this browser and are only sent to their provider.</p>
				</div>
			</div>
			<p id="key-modal-message" class="mt-4 hidden rounded-lg border border-[var(--color-accent)]/30 bg-[var(--color-accent)]/10 px-3 py-2 text-[12px] text-[var(--color-accent)]" role="status"></p>
			<div class="no-scrollbar mt-4 max-h-[min(60vh,560px)] space-y-3 overflow-y-auto pr-1">
				{PROVIDER_LIST.map((provider) => (
					<div data-key-provider={provider.id}>
						<div class="mb-1 flex items-center justify-between gap-3">
							<span class="flex items-center gap-1.5 text-[11px] text-[var(--color-ink-dim)]">
								<img
									src={provider.logo}
									alt=""
									class:list={["size-4 object-contain", { "brightness-0 invert": provider.logoMonochrome }]}
								/>
								{provider.name}
							</span>
							{provider.keyUrl ? (
								<a href={provider.keyUrl} target="_blank" rel="noopener" class="text-[10px] text-[var(--color-ink-faint)] underline-offset-2 hover:text-[var(--color-ink-dim)] hover:underline">get a key →</a>
							) : (
								<span class="text-[10px] text-[var(--color-ink-faint)]">{provider.credentialHelp}</span>
							)}
						</div>
						<div class="control-surface flex items-center gap-2 px-3 focus-within:border-[var(--color-accent)]/45">
							<input
								id={`api-key-${provider.id}`}
								type={provider.id === "local" ? "text" : "password"}
								inputmode={provider.id === "local" ? "url" : "text"}
								placeholder={provider.keyPlaceholder}
								aria-label={`${provider.name} ${provider.credentialLabel}`}
								autocomplete="off"
								spellcheck="false"
								class:list={["w-full bg-transparent font-mono text-[13px] text-[var(--color-ink)] outline-none placeholder:text-[var(--color-ink-faint)]"]}
							/>
						</div>
						{provider.credentialHelp && provider.id !== "local" && (
							<p class="mt-1 text-[10px] leading-relaxed text-[var(--color-ink-faint)]">{provider.credentialHelp}</p>
						)}
						{provider.id === "local" && (
							<p class="mt-1 text-[10px] leading-relaxed text-[var(--color-ink-faint)]">Make sure your local server has CORS enabled.</p>
						)}
					</div>
				))}
			</div>
			<div class="mt-4 flex items-center justify-end gap-2">
				<button id="key-cancel" class="control-surface px-4 text-[12px]">
					Cancel
				</button>
				<button id="key-save" class="action-primary flex items-center gap-1.5 px-4 text-[12px] font-semibold">
					<svg class="size-4"><use href="#i-check"></use></svg>
					<span>Save</span>
				</button>
			</div>
		</div>
	</div>

	<!-- ============================== HISTORY DRAWER ============================== -->
	<div id="history-drawer" class="fixed inset-0 z-50 hidden" role="dialog" aria-modal="true" aria-labelledby="history-title">
		<div id="history-backdrop" class="absolute inset-0 bg-black/80 backdrop-blur-md"></div>
		<aside
			id="history-panel"
			class="absolute right-0 top-0 flex h-full w-[min(94vw,480px)] translate-x-full flex-col border-l border-[var(--color-line-hi)] bg-[var(--color-panel)] shadow-2xl transition-transform duration-300"
		>
			<header class="flex items-center gap-2.5 border-b border-[var(--color-line)] px-4 py-3.5">
				<span class="grid size-10 place-items-center rounded-xl bg-[var(--color-accent)]/10 text-[var(--color-accent)]">
					<svg class="size-5"><use href="#i-history"></use></svg>
				</span>
				<div class="flex-1">
					<h2 id="history-title" class="text-[14px] font-medium text-[var(--color-ink)]">Battle history</h2>
					<p class="text-[11px] text-[var(--color-ink-faint)]">stored locally in this browser</p>
				</div>
				<button id="history-clear" aria-label="Clear battle history" class="hidden items-center gap-1.5 rounded-md border border-[var(--color-line)] px-2 py-1.5 text-[11px] text-[var(--color-ink-faint)] transition-colors hover:border-red-500/40 hover:text-red-400">
					<svg class="size-3.5"><use href="#i-trash"></use></svg>
					<span>clear</span>
				</button>
				<button id="history-close" aria-label="Close battle history" class="grid size-8 place-items-center rounded-md text-[var(--color-ink-faint)] transition-colors hover:bg-[var(--color-line)] hover:text-[var(--color-ink)]">
					<svg class="size-4"><use href="#i-x"></use></svg>
				</button>
			</header>
			<div id="history-list" class="flex-1 overflow-y-auto p-3"></div>
		</aside>
	</div>
</Layout>

<script src="../scripts/app.ts"></script>
