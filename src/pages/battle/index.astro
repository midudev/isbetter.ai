---
import Layout from "../../layouts/Layout.astro";
import ArenaFooter from "../../components/ArenaFooter.astro";
import ArenaHeader from "../../components/ArenaHeader.astro";
import ViewToolbar from "../../components/ViewToolbar.astro";
---

<Layout>
	<div class="app-shell flex flex-col">
		<!-- ================================ HEADER ================================ -->
		<ArenaHeader variant="review" />

		<!-- ============================== NOT FOUND ============================== -->
		<div id="battle-notfound" class="hidden flex-1 place-items-center py-24 text-center">
			<div class="flex flex-col items-center gap-4">
				<span class="grid size-14 place-items-center rounded-2xl border border-[var(--color-line)] text-[var(--color-ink-faint)]">
					<svg class="size-7"><use href="#i-history"></use></svg>
				</span>
				<div class="max-w-sm">
					<p class="font-pixel text-[13px] tracking-[0.1em] text-[var(--color-ink-dim)]">battle not found</p>
					<p class="mt-2 text-[12px] leading-relaxed text-[var(--color-ink-faint)]">
						This local or public battle could not be found. Check that the shared link is complete.
					</p>
					<a href="/" class="mt-4 inline-flex items-center gap-1.5 rounded-lg bg-[var(--color-accent)] px-4 py-2 text-[12px] font-medium text-black transition-opacity hover:opacity-90">
						<svg class="icon-fill size-4"><use href="#i-bolt"></use></svg>
						<span>back to the arena</span>
					</a>
				</div>
			</div>
		</div>

		<!-- ============================== BATTLE VIEW ============================== -->
		<div id="battle-view" class="hidden flex-1 flex-col">
			<section class="py-4 sm:py-5">
				<div class="section-label">
					<svg class="size-3.5"><use href="#i-clock"></use></svg>
					<span id="battle-when">—</span>
				</div>
				<p id="battle-prompt" class="mt-3 max-w-5xl text-[14px] leading-relaxed text-[var(--color-ink)] sm:text-[15px]"></p>
			</section>

			<div class="mt-5"><ViewToolbar variant="review" /></div>
			<section id="results" role="tabpanel" class="grid gap-4 py-5 sm:py-6 grid-cols-[repeat(auto-fill,minmax(min(22rem,100%),1fr))]"></section>
			<section id="battle-summary" class="mb-6 overflow-hidden">
				<header class="flex flex-wrap items-center gap-3 border-b border-[var(--color-line)] px-4 py-3">
					<svg class="size-4 text-[var(--color-accent)]"><use href="#i-trophy"></use></svg>
					<h2 class="text-[11px] uppercase tracking-[0.18em] text-[var(--color-ink-dim)]">Battle summary</h2>
				</header>
				<div class="grid border-b border-[var(--color-line)] lg:grid-cols-[minmax(0,2fr)_minmax(16rem,1fr)]">
					<div id="battle-timeline" class="min-w-0 border-b border-[var(--color-line)] lg:border-b-0 lg:border-r"></div>
					<aside id="battle-insights"></aside>
				</div>
				<div class="scroll-affordance"><div id="battle-summary-list" class="overflow-x-auto"></div></div>
			</section>
		</div>

		<ArenaFooter review />
	</div>
</Layout>

<script src="../../scripts/battle.ts"></script>
